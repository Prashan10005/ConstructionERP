@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Project Manager Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="bg-light">

    <!-- NAVBAR -->
    <nav class="navbar navbar-light bg-white shadow-sm px-3">
        <h5 class="mb-0">
            <i class="fas fa-project-diagram"></i> Project Manager Dashboard
        </h5>

        <div>
            <span id="userName" class="me-3"></span>
        </div>

        <button class="btn btn-outline-danger btn-sm" onclick="logout()">Logout</button>
    </nav>

    <!-- MODULE CARDS -->
    <div class="container mt-5">

        <div class="row g-4">

            <!-- PROJECT MODULE -->
            <div class="col-md-4">
                <div class="card shadow text-center p-4">

                    <i class="fas fa-project-diagram fa-3x text-primary mb-3"></i>

                    <h5>Project Management</h5>
                    <p>Manage projects, tasks and status</p>

                    <a href="/ProjectManager/Project" class="btn btn-primary">
                        Open Module
                    </a>

                </div>
            </div>

            <!-- MATERIAL MODULE -->
            <div class="col-md-4">
                <div class="card shadow text-center p-4">

                    <i class="fas fa-boxes fa-3x text-warning mb-3"></i>

                    <h5>Material Management</h5>
                    <p>Manage inventory and materials</p>

                    <a href="/ProjectManager/Material" class="btn btn-warning">
                        Open Module
                    </a>

                </div>
            </div>

        </div>

    </div>

    

    <div class="alert alert-success mt-3">
        <i class="fas fa-check-circle"></i>
        Login Successfull. Active Session is going on.
    </div>

    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        // check active token and admin role
        function checkAuth() {
            var token = localStorage.getItem('jwt_token');
            var role = localStorage.getItem('role');

            if (!token || role !== 'ProjectManager') {
                window.location.href = '/Account/Login';
                return false;
            }
            return true;
        }

        $('#userName').text('Welcome, ' + (localStorage.getItem('username')));

        // Attach token to ALL AJAX requests
        $.ajaxSetup({
            beforeSend: function (xhr) {
                var token = localStorage.getItem('jwt_token');
                if (token) {
                    xhr.setRequestHeader('Authorization', 'Bearer ' + token);
                }
            }
        });

        // LOGOUT
        function logout() {

            localStorage.removeItem("jwt_token");
            localStorage.removeItem("role");
            localStorage.removeItem("username");

            window.location.href = "/Account/Login";
        }

    </script>

</body>
</html>
