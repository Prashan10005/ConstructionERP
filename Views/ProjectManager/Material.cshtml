@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Project Manager Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="bg-light">

    <!-- NAVBAR -->
    <nav class="navbar navbar-light bg-white shadow-sm px-3">
        <h5 class="mb-0">
            <i class="fas fa-project-diagram"></i> Material Management
        </h5>

        <div>
            <span id="userName" class="me-3"></span>
        </div>

        <button class="btn btn-outline-danger btn-sm" onclick="logout()">Back to Home</button>
    </nav>

    <!-- TABS -->
    <div class="container mt-3">

        <ul class="nav nav-tabs">

            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#projectTab">
                    Material Request
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#taskTab">
                    Task Creation
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#statusTab">
                    Project Status
                </button>
            </li>

        </ul>

    </div>

    <!-- MAIN LAYOUT -->
    <div class="container-fluid mt-3">
        <div class="tab-content">


            <!-- Projects Tab-->
            <div class="tab-pane fade show active" id="projectTab">

                <div class="row mt-3">
                    <div class="card-header bg-primary text-white">
                        Material Request Form
                    </div>

                    <div class="card-body">

                        <form id="materialForm">

                            <select id="materialProjectDropdown" class="form-control mb-2"></select>

                            <select id="materialTaskDropdown" class="form-control mb-2"></select>

                            <input id="materialName" class="form-control mb-2" placeholder="Material Name">

                            <button id="createRequestBtn" class="btn btn-primary" type="button">
                                Submit Request
                            </button>

                        </form>

                        <div id="alertMaterial"></div>

                    </div>
                    

                    

                </div>

            </div>

            <!-- Task tab-->
            <div class="tab-pane fade" id="taskTab">

                <div class="card">

                    <div class="card-header bg-warning">
                        Task Creation
                    </div>

                    <div class="card-body">
                        

                    </div>

                </div>

            </div>

            <!-- Status tab-->
            <div class="tab-pane fade" id="statusTab">

                <div class="card">

                    <div class="card-header bg-secondary text-white">
                        Project Status Update
                    </div>

                    <div class="card-body">

                        

                    </div>

                </div>

            </div>
        </div>
    </div>

    <div class="alert alert-success mt-3">
        <i class="fas fa-check-circle"></i>
        Login Successfull. Active Session is going on.
    </div>

    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        // check active token and admin role
        function checkAuth() {
            var token = localStorage.getItem('jwt_token');
            var role = localStorage.getItem('role');

            if (!token || role !== 'ProjectManager') {
                window.location.href = '/Account/Login';
                return false;
            }
            return true;
        }

        // Attach token to ALL AJAX requests
        $.ajaxSetup({
            beforeSend: function (xhr) {
                var token = localStorage.getItem('jwt_token');
                if (token) {
                    xhr.setRequestHeader('Authorization', 'Bearer ' + token);
                }
            }
        });

        $(document).ready(function () {

            if (!checkAuth()) return;

            $('#userName').text('Welcome, ' + (localStorage.getItem('username')));
            
            loadProgressProjects();
        });


        function loadProgressProjects() {
            $.get('/api/material/projects', function (data) {

                $('#materialProjectDropdown').empty();
                $('#materialProjectDropdown').append(`<option value="">Select Project</option>`);

                $.each(data, function (i, p) {
                    $('#materialProjectDropdown').append(
                        `<option value="${p.projectId}">${p.projectName}</option>`
                    );
                });
            });
        }

        $('#materialProjectDropdown').change(function () {

            var projectId = $(this).val();

            $.get('/api/material/tasks?projectId=' + projectId, function (data) {

                $('#materialTaskDropdown').empty();
                $('#materialTaskDropdown').append(`<option value="">Select Task</option>`);

                $.each(data, function (i, t) {
                    $('#materialTaskDropdown').append(
                        `<option value="${t.taskId}">${t.taskName}</option>`
                    );
                });
            });
        });

        $('#createRequestBtn').click(function(e){
            e.preventDefault();

            var btn = $('#createRequestBtn');
            
            var projectId = $('#materialProjectDropdown').val();
            var taskId = $('#materialTaskDropdown').val();
            var materialName = $('#materialName').val().trim();

            //validation
            if(!projectId || !taskId || !materialName){
                $('#alertMaterial').html(`
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle"></i>
                        All fields are required.
                    </div>
                `);
                return;
            }

            btn.prop('disabled', true).text('submitting....');

            var data = {
                projectId: parseInt(projectId),
                taskId: parseInt(taskId),
                materialName: materialName
            };

            $.ajax({
                url: '/api/material/request',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {

                if (res.success) {
                    showAlert("Material request submitted successfully", "success", "#alertMaterial");

                // reset form
                $('#materialForm')[0].reset();
                $('#materialTaskDropdown').empty().append(`<option value="">Select Task</option>`);
                    } else {
                showAlert(res.message || "Failed to submit request", "danger", "#alertMaterial");
                }

                btn.prop('disabled', false).text('Submit Request');
                },

                error: function (xhr) {
                showAlert(xhr.responseJSON?.message || "Server error occurred", "danger", "#alertMaterial");
                btn.prop('disabled', false).text('Submit Request');
                }
            });
        });
        

        // ESCAPE HTML
        function escapeHtml(text) {
            if (!text) return '';
            return text
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }


        // LOGOUT
        function logout() {

            window.location.href = "/ProjectManager/Home";
        }

    </script>

</body>
</html>
