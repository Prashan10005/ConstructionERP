@{
    Layout = null;
}

<! DOCTYPE html>
<html>
    <head>
        <title> ADMIN DASHBOARD</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    </head>

    <body class="bg-light">

        <nav class="navbar navbar-light bg-white shadow-sm">
            <h5 class="mb-4">
            <i class="fas fa-hard-hat"></i> CONSTRUCTION SYSTEM - Admin
            </h5>

            <div>
                <span class="me-3"> Welcome, @ViewBag.Username</span>
            </div>

            <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                <button type="submit" class="btn btn-outline-danger btn-sm">
                    LOGOUT
                </button>
            </form>
        </nav>

        <div class="mb-3">
            <h4> <i class="fas fa-tachometer-alt"></i> Employe Management</h4>
        </div>

        <!--code the employee page here, form and grid to display details and also can show total count of employees at the bottom-->

        <div class="alert alert-success mt-3">
            <i class="fas fa-check-circle"></i>
            Login Successfull. Active Session is going on.
        </div>

    </body>
</html>
