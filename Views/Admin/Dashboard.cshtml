@{
    Layout = null;
}

<!DOCTYPE html>
<html>
    <head>
        <title> ADMIN DASHBOARD</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    </head>

    <body class="bg-light">

        <nav class="navbar navbar-light bg-white shadow-sm">
            <h5 class="mb-4">
            <i class="fas fa-hard-hat"></i> CONSTRUCTION SYSTEM - Admin
            </h5>

            <div>
                <span id="userName" class="me-3"></span>
            </div>

        <button class="btn btn-outline-danger btn-sm" onclick="logout()">
            LOGOUT
        </button>
        </nav>

        <div class="mb-3">
            <h4> <i class="fas fa-tachometer-alt"></i> Employe Management</h4>
        </div>

         <div class="row mt-4">
             <div class="col-md-5">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">USER REGISTRATION FORM</h5>
                    </div>
                    <div class="card-body">
                        <form id="createUserForm">
                            <div class="mb-3">
                                <label class="form-label">User ID</label>
                                <input id="UserId" type="text" class="form-control" value="Auto-generated" disabled />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">User Name</label>
                                <input id="Username" type="text" class="form-control" placeholder="Enter Username" required/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input id="Email" type="email" class="form-control" placeholder="Enter Email" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input id="Password" type="password" class="form-control" placeholder="Enter Password with min 8 Charecters"/>
                                <span class="list-group-text fa-solid fa-eye toggle-password" style="cursor:pointer;" onclick="togglePassword()"></span>
                                <small id="passwordHint" class="text-muted">Leave blank to keep current password when updating</small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Role</label>
                                <select id="Role" class="form-select" required> 
                                    <option value="ProjectManager">Project Manager</option>
                                    <option value="FieldStaff">Field Staff</option>
                                </select>
                            </div>

                            <div class="mb-3 form-check">
                                <label class="form-check-label">Active </label>
                                <input type="checkbox" id="IsActive" class="form-check-input" checked />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Created At</label>
                                <input id="CreatedAt" type="text" class="form-control" disabled />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Last Login At</label>
                                <input id="LastloginAt" type="text" class="form-control" disabled />
                            </div>

                            <div class="d-flex gap-2">
                                <button id="createBtn" type="submit" class="btn btn-primary flex-grow-1">Create User</button>
                                <button id="updateBtn" type="button" class="btn btn-primary flex-grow-1">Update User</button>
                                <button id="clearBtn" type="button" class="btn btn-secondary" >Clear</button>
                            </div>
                            

                        <div class="row mt-3">
                            <div class="col-md-12">
                                <div id="alertMessage"></div>
                            </div>
                        </div>

                        </form>
                    </div> 
                </div>
             </div>
             <div class="col-md-7">
                 <div class="card">
                     <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Registered User List</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Username</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="userTableBody">
                                    <tr>
                                        <td colspan="5" class="text-center">Loading users...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                 </div>

             </div>
         </div>

        <div class="alert alert-success mt-3">
            <i class="fas fa-check-circle"></i>
            Login Successfull. Active Session is going on.
        </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script type="text/javascript">
        var isUpdateMode = false;
        var selectedUserId = 0;

        // check active token and admin role
        function checkAuth() {
            var token = localStorage.getItem('jwt_token');
            var role = localStorage.getItem('role');

            if (!token || role !== 'Admin') {
                window.location.href = '/Account/Login';
                return false;
            }
            return true;
        }

        // Attach token to ALL AJAX requests
        $.ajaxSetup({
            beforeSend: function (xhr) {
                var token = localStorage.getItem('jwt_token');
                if (token) {
                    xhr.setRequestHeader('Authorization', 'Bearer ' + token);
                }
            }
        });

        
        //toggle password
        function togglePassword() {
            const password = document.getElementById('Password');
            const icon = document.querySelector('.toggle-password');
            if (password.type === 'text') {
                password.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            } else {
                password.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            }
        }

        // Load users at page load
        $(document).ready(function () {

            if (!checkAuth()) return;

            $('#userName').text('Welcome, ' + (localStorage.getItem('username') || 'Admin'));

            loadUsers();

            $('#clearBtn').click(clearForm);
            $('#updateBtn').click(updateUser);
        });

        // Load all users to the grid
        function loadUsers() {

            $.ajax({
                url: '/api/user',
                type: 'GET',
                success: function (response) {

                    var tbody = $('#userTableBody');
                    tbody.empty();

                    if (!response.success || !response.data || response.data.length === 0) {
                        tbody.append('<tr><td colspan="5" class="text-center">No users found</td></tr>');
                        return;
                    }

                    $.each(response.data, function (index, user) {

                        var statusBadge = user.isActive
                            ? '<span class="badge bg-success">Active</span>'
                            : '<span class="badge bg-danger">Inactive</span>';

                        var roleBadge =
                            user.role === 'ProjectManager'
                                ? '<span class="badge bg-primary">Project Manager</span>'
                                : '<span class="badge bg-warning">Field Staff</span>';

                        var row = `
                            <tr>
                                <td>${escapeHtml(user.username)}</td>
                                <td>${escapeHtml(user.email)}</td>
                                <td>${roleBadge}</td>
                                <td>${statusBadge}</td>
                                <td>
                                    <button class="btn btn-sm btn-info" onclick="viewUser(${user.userID})">
                                        View
                                    </button>
                                </td>
                            </tr>
                        `;

                        tbody.append(row);
                    });
                },
                error: function (xhr) {
                        console.log("STATUS:", xhr.status);
                        console.log("RESPONSE:", xhr.responseText); 
                        showAlert('Error loading users', 'danger');
                }
            });
        }

        //Get single user by ID
        function viewUser(id) {

            $.ajax({
                url: '/api/user/' + id,
                type: 'GET',
                success: function (response) {

                    if (!response.success) return;

                    var user = response.data;

                    $('#UserId').val(user.userID);
                    $('#Username').val(user.username);
                    $('#Email').val(user.email);
                    $('#Password').val('');
                    $('#Role').val(user.role);
                    $('#IsActive').prop('checked', user.isActive);
                    $('#CreatedAt').val(user.createdAt);
                    $('#LastloginAt').val(user.lastLoginAt || 'Never logged in');

                    isUpdateMode = true;
                    selectedUserId = user.userID;

                    $('#createBtn').prop('disabled', true);
                    $('#updateBtn').prop('disabled', false);

                    showAlert('User loaded successfully', 'success');
                },
                error: function () {
                    showAlert('Error loading user', 'danger');
                }
            });
        }

        //Clear form
        function clearForm() {

            $('#createUserForm')[0].reset();

            $('#UserId').val('Auto-generated');

            isUpdateMode = false;
            selectedUserId = 0;

            $('#createBtn').prop('disabled', false);
            $('#updateBtn').prop('disabled', true);

            showAlert('Form cleared', 'info');
        }

        // Create user
        $('#createBtn').click(function (e) {
            e.preventDefault();
            
            var username = $('#Username').val().trim();
            var email = $('#Email').val().trim();
            var password = $('#Password').val().trim();

            // client side validation
            if (!username) {
                showAlert("Username is required", "danger");
                return;
            }

            if (!email) {
                showAlert("Email is required", "danger");
                return;
            }

            if (!password) {
                showAlert("Password is required", "danger");
                return;
            }

            if (password.length < 8) {
                showAlert("Password must be at least 8 characters", "danger");
                return;
            }
            var btn = $('#createBtn');
            btn.prop('disabled', true).text('Creating...');

            var userData = {
                username: username,
                email: email,
                password: password,
                role: $('#Role').val(),
                isActive: $('#IsActive').is(':checked')
            };

            $.ajax({
                url: '/api/user/create',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(userData),
                success: function (response) {

                    if (response.success) {
                        showAlert('User created successfully', 'success');
                        $('#createUserForm')[0].reset();
                        loadUsers();
                    } else {
                        showAlert('Failed to create user', 'danger');
                    }

                    btn.prop('disabled', false).text('Create User');
                },
                error: function (xhr) {
                    showAlert(xhr.responseJSON?.message || 'Error creating user', 'danger');
                    btn.prop('disabled', false).text('Create User');
                }
            });
        });

        // update user
        function updateUser() {

            var username = $('#Username').val().trim();
            var email = $('#Email').val().trim();
            var password = $('#Password').val().trim();

            // client side validation
            if (!username) {
                showAlert("Username is required", "danger");
                return;
            }

            if (!email) {
                showAlert("Email is required", "danger");
                return;
            }

            if (password && password.length < 8) {
                showAlert("Password must be at least 8 characters", "danger");
                return;
            }

            var btn = $('#updateBtn');
            btn.prop('disabled', true).text('Updating...');

            var userData = {
                username: username,
                email: email,
                role: $('#Role').val(),
                isActive: $('#IsActive').is(':checked')
            };

            // only update if password is entered
            if (password) {
                userData.password = password;
            }

            $.ajax({
                url: '/api/user/' + selectedUserId,
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify(userData),
                success: function (response) {

                    if (response.success) {
                        showAlert('User updated successfully', 'success');
                        clearForm();
                        loadUsers();
                    } else {
                        showAlert('Update failed', 'danger');
                    }

                    btn.prop('disabled', false).text('Update User');
                },
                error: function (xhr) {
                    showAlert(xhr.responseJSON?.message || 'Error updating user', 'danger');
                    btn.prop('disabled', false).text('Update User');
                }
            });
        }

        // alert message
        function showAlert(message, type) {
            $('#alertMessage').html(`
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);

            // Auto hide after 3 seconds
            setTimeout(function() {
                $('.alert').alert('close');
            }, 3000);
        }

        // escape HTML text to convert to default
        function escapeHtml(text) {
            if (!text) return '';
            return text
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }
    
        // Logout function
        function logout() {

            // CLEAR ALL AUTH DATA
            localStorage.removeItem('jwt_token');
            localStorage.removeItem('role');
            localStorage.removeItem('username');
            localStorage.removeItem('user_id');
            localStorage.removeItem('token_expiry');

            // REDIRECT TO LOGIN
            window.location.href = '/Account/Login';
        }
    </script>
    
    </body>
</html>
