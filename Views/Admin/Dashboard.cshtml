@{
    Layout = null;
}

<!DOCTYPE html>
<html>
    <head>
        <title> ADMIN DASHBOARD</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    </head>

    <body class="bg-light">

        <nav class="navbar navbar-light bg-white shadow-sm">
            <h5 class="mb-4">
            <i class="fas fa-hard-hat"></i> CONSTRUCTION SYSTEM - Admin
            </h5>

            <div>
                <span class="me-3"> Welcome, @ViewBag.Username</span>
            </div>

            <form id="logoutForm" method="post" class="d-inline">
                <button id="Logout" type="submit" class="btn btn-outline-danger btn-sm" onclick="logout()">
                    LOGOUT
                </button>
            </form>
        </nav>

        <div class="mb-3">
            <h4> <i class="fas fa-tachometer-alt"></i> Employe Management</h4>
        </div>

         <div class="row mt-4">
             <div class="col-md-5">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">USER REGISTRATION FORM</h5>
                    </div>
                    <div class="card-body">
                        <form id="createUserForm">
                            <div class="mb-3">
                                <label class="form-label">User ID</label>
                                <input id="UserId" type="text" class="form-control" value="Auto-generated" disabled />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">User Name</label>
                                <input id="Username" type="text" class="form-control" placeholder="Enter Username" required/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input id="Email" type="email" class="form-control" placeholder="Enter Email" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input id="Password" type="password" class="form-control" placeholder="Enter Password with min 8 Charecters"/>
                                <span class="list-group-text fa-solid fa-eye toggle-password" style="cursor:pointer;" onclick="togglePassword()"></span>
                                <small id="passwordHint" class="text-muted">Leave blank to keep current password when updating</small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Role</label>
                                <select id="Role" class="form-select" required> 
                                    <option value="ProjectManager">Project Manager</option>
                                    <option value="FieldStaff">Field Staff</option>
                                </select>
                            </div>

                            <div class="mb-3 form-check">
                                <label class="form-check-label">Active </label>
                                <input type="checkbox" id="IsActive" class="form-check-input" checked />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Created At</label>
                                <input id="CreatedAt" type="text" class="form-control" disabled />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Last Login At</label>
                                <input id="LastloginAt" type="text" class="form-control" disabled />
                            </div>

                            <div class="d-flex gap-2">
                                <button id="createBtn" type="submit" class="btn btn-primary flex-grow-1">Create User</button>
                                <button id="updateBtn" type="button" class="btn btn-primary flex-grow-1">Update User</button>
                                <button id="clearBtn" type="button" class="btn btn-secondary" >Clear</button>
                            </div>
                            

                        <div class="row mt-3">
                            <div class="col-md-12">
                                <div id="alertMessage"></div>
                            </div>
                        </div>

                        </form>
                    </div> 
                </div>
             </div>
             <div class="col-md-7">
                 <div class="card">
                     <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Registered User List</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Username</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="userTableBody">
                                    <tr>
                                        <td colspan="4" class="text-center">Loading users...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                 </div>

             </div>
         </div>

        <div class="alert alert-success mt-3">
            <i class="fas fa-check-circle"></i>
            Login Successfull. Active Session is going on.
        </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script type="text/javascript">
        var isUpdateMode = false;
        var selectedUserId = 0;
        
        //toggle password
        function togglePassword() {
            const password = document.getElementById('Password');
            const icon = document.querySelector('.toggle-password');
            if (password.type === 'text') {
                password.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            } else {
                password.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            }
        }

        // Load users at page load
        $(document).ready(function(){
            loadUsers();

            // clear button function call
            $('#clearBtn').click(function(){
                clearForm();
            });     

            // update button function call
            $('#updateBtn').click(function(){
                updateUser();
            });
        
        });

        // Get all users
        function loadUsers() {
            $.ajax({
                url: '/api/auth/get-users',
                type: 'GET',
                success: function(response) {
                    if (response.success && response.users) {
                        var tbody = $('#userTableBody');
                        tbody.empty();

                        if (response.users.length === 0) {
                            tbody.append('<tr><td colspan="4" class="text-center">No users found</td></tr>');
                        } else {
                            $.each(response.users, function(index, user) {
                                var statusBadge = user.isActive ?
                                    '<span class="badge bg-success">Active</span>' :
                                    '<span class="badge bg-danger">Inactive</span>';

                                var roleBadge = user.role === 'ProjectManager' ?
                                    '<span class="badge bg-primary">Project Manager</span>' :
                                    '<span class="badge bg-warning">Field Staff</span>';

                                var row = `
                                    <tr>
                                        <td>${escapeHtml(user.username)}</td>
                                        <td>${escapeHtml(user.email)}</td>
                                        <td>${roleBadge}</td>
                                        <td>${statusBadge}</td>
                                        <td><button class="btn btn-sm btn-info" onclick="viewUser(${user.userID})">View</button></td>
                                    </tr>
                                `;
                                tbody.append(row);
                            });
                        }
                    } else {
                        $('#userTableBody').html('<tr><td colspan="4" class="text-center text-danger">Failed to load users</td></tr>');
                    }
                },
                error: function(xhr) {
                    $('#userTableBody').html('<tr><td colspan="4" class="text-center text-danger">Error loading users</td></tr>');
                    showAlert('Error loading users', 'danger');
                }
            });
        }

        //Get single user by ID
        function viewUser(Id) {
            $.ajax({
                url: `/api/auth/get-user/`+ Id,
                type: 'GET',
                success: function(response) {
                    if (response.success && response.user) {
                        var user = response.user;
                        // display details in form
                        $('#SelectedUserId').val(user.userID);
                        $('#UserId').val(user.userID);
                        $('#Username').val(user.username);
                        $('#Email').val(user.email);
                        $('#Password').val('');
                        $('#Role').val(user.role);
                        $('#IsActive').prop('checked', user.isActive);
                        $('#CreatedAt').val(user.createdAt);
                        $('#LastloginAt').val(user.lastLoginAt || 'Never logged in');
                        
                        isUpdateMode = true;
                        selectedUserId = user.userID;
                        $('#createBtn').prop('disabled', true);
                        $('#updateBtn').prop('disabled', false);
                        $('#passwordRequired').html('<span class="text-muted">(Optional - leave blank to keep current)</span>');
                        $('#passwordHint').show();

                        showAlert('User loaded. Make changes and click Update User.', 'success');
                    } 
                },
                error: function(xhr) {
                    showAlert('Error loading user details', 'danger');
                }
            });
        }
        //Clear form
        function clearForm() {
            $('#createUserForm')[0].reset();
            $('#SelectedUserId').val('0');
            $('#UserID').val('Auto-generated');
            $('#IsActive').prop('checked', true);
            $('#Password').val('');

            isUpdateMode = false;
            selectedUserId = 0;
            $('#createBtn').prop('disabled', false);
            $('#updateBtn').prop('disabled', true);
            $('#passwordRequired').html('*');
            $('#passwordHint').hide();

            showAlert('Form cleared. Ready to create new user.', 'info');
        }

        // Create user
        $('#createBtn').click(function(e) {
            e.preventDefault();
            
            // Get form data
            var userData = {
                Username: $('#Username').val().trim(),
                Email: $('#Email').val().trim(),
                Password: $('#Password').val(),
                Role: $('#Role').val(),
                IsActive: $('#IsActive').is(':checked')
            };

            if (userData.Password.length < 8) {
                showAlert('Password must be at least 8 characters', 'danger');
                return;
            }
            
            // Show loading state
            var btn = $(this).find('button[type="submit"]');
            var originalText = btn.html();
            btn.prop('disabled', true);
            btn.html('Creating...');
            
            // Call REST API
            $.ajax({
                url: '/api/auth/create-user',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(userData),
                success: function(response) {
                    if (response.success) {
                        showAlert(response.message, 'success');
                        // Clear form
                        $('#createUserForm')[0].reset();
                        $('#IsActive').prop('checked', true);
                        // Reload user list
                        loadUsers();
                    } else {
                        showAlert(response.message, 'danger');
                    }
                    btn.prop('disabled', false);
                    btn.html(originalText);
                },
                error: function(xhr) {
                    var errorMsg = 'Error creating user';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMsg = xhr.responseJSON.message;
                    }
                    showAlert(errorMsg, 'danger');
                    btn.prop('disabled', false);
                    btn.html(originalText);
                }
            });
        });

        // update user
        function updateUser(){
            var userData ={
                Username: $('#Username').val().trim(),
                Email: $('#Email').val().trim(),
                Role: $('#Role').val(),
                IsActive: $('#IsActive').is(':checked')
            };
                var password = $('#Password').val();

            if (password) {
                if (password.length < 8) {
                    showAlert('Password must be at least 8 characters', 'danger');
                    return;
                }
                userData.Password = password;
             }

            // make the button disabled while updating
            var btn = $('#updateBtn');
            var originalText = btn.html();
            btn.prop('disabled', true);
            btn.html('Updating...');

            $.ajax({
                url: '/api/auth/update-user/' + selectedUserId,
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify(userData),
                success: function(response) {
                    if (response.success) {
                        showAlert(response.message, 'success');
                        // Clear form
                        clearForm();
                        // Reload user list
                        loadUsers();
                    } else {
                        showAlert(response.message, 'danger');
                    }
                    btn.prop('disabled', false);
                    btn.html(originalText);
                },

                error: function(xhr) {
                    console.log(xhr.responseText); // 🔥 IMPORTANT

                    var errorMsg = xhr.responseJSON?.message || 'Error updating user';
                    showAlert(errorMsg, 'danger');

                    btn.prop('disabled', false);
                    btn.html(originalText);

                }
                
            });

        }

        // alert message
        function showAlert(message, type) {
            $('#alertMessage').html(`
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);

            // Auto hide after 3 seconds
            setTimeout(function() {
                $('.alert').alert('close');
            }, 3000);
        }

        // escape HTML text to convert to default
        function escapeHtml(text) {
            if (!text) return '';
            return text
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }
    
        // Logout function
         function logout() {
            $.ajax({
                url: '/api/auth/logout',
                type: 'POST',
                success: function (response) {
                    if (response.success) {
                        window.location.href = '/Account/Login';
                    }
                },
                error: function () {
                    alert("Logout failed");
                }
            });
         }
    </script>
    
    </body>
</html>
