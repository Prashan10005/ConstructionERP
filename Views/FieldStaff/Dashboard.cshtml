@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Field Staff Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="bg-light">

    <!-- NAVBAR -->
    <nav class="navbar navbar-light bg-white shadow-sm px-3">
        <h5 class="mb-0">
            <i class="fas fa-tasks"></i> Field Staff Dashboard
        </h5>

        <div>
            <span id="userName" class="me-3"></span>
        </div>

        <button class="btn btn-outline-danger btn-sm" onclick="logout()">Logout</button>
    </nav>

    <!-- MAIN -->
    <div class="container mt-3">

        <div class="card">
            <div class="card-header bg-primary text-white">
                My Pending Tasks
            </div>

            <div class="card-body">

                <table class="table table-bordered table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>Task Name</th>
                            <th>Project</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody id="taskTable">
                        <tr>
                            <td colspan="5" class="text-center">Loading tasks...</td>
                        </tr>
                    </tbody>
                </table>

                <div id="alertMessageTask" class="mt-3"></div>

            </div>
        </div>

    </div>

    <div class="alert alert-success mt-3">
        <i class="fas fa-check-circle"></i>
        Login Successfull. Active Session is going on.
    </div>

    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

        // AUTH CHECK
        function checkAuth() {
            var token = localStorage.getItem('jwt_token');
            var role = localStorage.getItem('role');

            if (!token || role !== 'FieldStaff') {
                window.location.href = '/Account/Login';
                return false;
            }
            return true;
        }

        // Attach token to ALL AJAX
        $.ajaxSetup({
            beforeSend: function (xhr) {
                var token = localStorage.getItem('jwt_token');
                if (token) {
                    xhr.setRequestHeader('Authorization', 'Bearer ' + token);
                }
            }
        });

        $(document).ready(function () {

            if (!checkAuth()) return;

            $('#userName').text('Welcome, ' + localStorage.getItem('username'));

            loadMyTasks();
        });

        // LOAD TASKS
        function loadMyTasks() {

            $.ajax({
                url: '/api/task/mytasks',
                type: 'GET',
                success: function (data) {

                    var tbody = $('#taskTable');
                    tbody.empty();

                    if (!data || data.length === 0) {
                        tbody.append('<tr><td colspan="5" class="text-center">No tasks assigned</td></tr>');
                        return;
                    }

                    $.each(data, function (i, t) {

                        var statusBadge = '<span class="badge bg-warning">Open</span>';

                        var row = `
                            <tr>
                                <td>${escapeHtml(t.taskName)}</td>
                                <td>${escapeHtml(t.projectName)}</td>
                                <td>${escapeHtml(t.taskDescription)}</td>
                                <td>${statusBadge}</td>
                                <td>
                                    <button class="btn btn-success btn-sm"
                                        onclick="completeTask(${t.taskId})">
                                        Complete
                                    </button>
                                </td>
                            </tr>
                        `;

                        tbody.append(row);
                    });
                },
                error: function () {
                    showAlert("Error loading tasks", "danger", "#alertMessageTask");
                }
            });
        }

        // COMPLETE TASK
        function completeTask(taskId) {

            if (!confirm("Mark this task as completed?")) return;

            $.ajax({
                url: '/api/task/complete',
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify({ taskId: taskId }),

                success: function (res) {

                    if (res.success) {
                        showAlert("Task completed successfully", "success", "#alertMessageTask");
                        loadMyTasks();
                    } else {
                        showAlert(res.message || "Failed to complete task", "danger", "#alertMessageTask");
                    }
                },
                error: function (xhr) {
                    showAlert(xhr.responseJSON?.message || "Server error", "danger", "#alertMessageTask");
                }
            });
        }

        // ALERT FUNCTION (Reusable)
        function showAlert(message, type, targetId = "#alertMessageTask") {

            $(targetId).html(`
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);

            setTimeout(function () {
                $(targetId + " .alert").alert('close');
            }, 3000);
        }

        // ESCAPE HTML
        function escapeHtml(text) {
            if (!text) return '';
            return text
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        // LOGOUT
        function logout() {
            localStorage.removeItem("jwt_token");
            localStorage.removeItem("role");
            localStorage.removeItem("username");

            window.location.href = "/Account/Login";
        }

    </script>

</body>
</html>