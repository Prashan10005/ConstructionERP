@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Construction ERP - Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
</head>

<body>

    <div class="container-fluid">
        <div class="row vh-100">

            <!-- LEFT IMAGE -->
            <div class="col-md-6 d-none d-md-block p-0">
                <img src="~/images/loginImage.jpg"
                     class="w-100 h-100"
                     style="object-fit: cover;"
                     alt="Construction ERP" />
            </div>

            <!-- LOGIN FORM -->
            <div class="col-md-6 d-flex align-items-center justify-content-center">

                <div style="width:100%; max-width:380px;">

                    <div class="text-center mb-4">
                        <h2 class="fw-bold">Construction ERP</h2>
                        <p class="text-muted">Sign in to your account</p>
                    </div>

                    <div id="alertBox"></div>

                    <form id="loginForm">

                        <!-- EMAIL -->
                        <div class="mb-3">
                            <label>Email</label>
                            <input type="email" id="email" class="form-control" placeholder="Enter email" />
                        </div>

                        <!-- PASSWORD -->
                        <div class="mb-3">
                            <label>Password</label>

                            <div class="input-group">
                                <input type="password" id="password" class="form-control" placeholder="Enter password" />

                                <span class="input-group-text" style="cursor:pointer;" onclick="togglePassword()">
                                    <i id="eyeIcon" class="fa fa-eye"></i>
                                </span>
                            </div>
                        </div>

                        <!-- BUTTON -->
                        <button type="submit" id="loginBtn" class="btn btn-primary w-100">
                            Login
                        </button>

                    </form>

                </div>

            </div>

        </div>
    </div>

    <!-- SCRIPTS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

        // PASSWORD TOGGLE
        function togglePassword() {
            var pass = document.getElementById("password");
            var icon = document.getElementById("eyeIcon");

            if (pass.type === "password") {
                pass.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            } else {
                pass.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }
        }

        // LOGIN SUBMIT
        $('#loginForm').on('submit', function (e) {
            e.preventDefault();

            var email = $('#email').val();
            var password = $('#password').val();
            var btn = $('#loginBtn');

            if (!email || !password) {
                showAlert("Email and Password required", "danger");
                return;
            }

            btn.prop('disabled', true);
            btn.html('<i class="fa fa-spinner fa-spin"></i> Logging in...');

            $.ajax({
                url: '/api/auth/login',
                type: 'POST',
                contentType: 'application/json',

                // DTO MAPPING (LoginRequestDto)
                data: JSON.stringify({
                    email: email,
                    password: password
                }),

                success: function (response) {

                    if (response.success) {

                        var data = response.data; // LoginResponseDto

                        // Store JWT
                        localStorage.setItem("jwt_token", data.token);
                        localStorage.setItem("role", data.role);
                        localStorage.setItem("username", data.username);

                        showAlert("Login successful", "success");

                        setTimeout(function () {
                            window.location.href = data.redirectUrl;
                        }, 800);

                    } else {
                        showAlert(response.message, "danger");
                    }

                    btn.prop('disabled', false);
                    btn.html('Login');
                },

                error: function (xhr) {

                    var msg = "Login failed";

                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        msg = xhr.responseJSON.message;
                    }

                    showAlert(msg, "danger");

                    btn.prop('disabled', false);
                    btn.html('Login');
                }
            });
        });

        // ALERT FUNCTION
        function showAlert(message, type) {
            $('#alertBox').html(`
                <div class="alert alert-${type} alert-dismissible fade show">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);

            setTimeout(() => {
                $(".alert").alert("close");
            }, 3000);
        }

    </script>

</body>
</html>