@model ConstructionERP.Models.ViewModels.LoginViewModel

@{
    Layout = null;
}

<! DOCTYPE html>
<html>
<head>
    <title> ADMIN DASHBOARD</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <div class="container-fluid">
        <div class="row vh-100">
            <div class="col-md-6 d-none d-md-block p-0">
                <img src="~/images/loginImage.jpg" class="img-fluid w-100 h-100" style="object-fit:cover;" alt="Constuction Image" />
            </div>

            <div class="col-md-6 d-flex align-items-center justify-content-center">
                <div style="width: 100%; max-width: 350px;">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold">Construction ERP</h2>
                        <p class="text-muted mb-0">Welcome back</p>
                        <p class="text-muted small">Sign in to continue to your dashboard</p>
                    </div>
                    <div id="alertMessage"></div>

                    <form id="LoginForm">
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" id="Email" class="form-control" placeholder="Enter email" required />
                            <span class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <div class="input-group">
                                <input id="Password" type="password" class="form-control" placeholder="Enter password" required />
                                <span class="input-group-text fa-solid fa-eye toggle-password" style="cursor:pointer;" onclick="togglePassword()"></span>
                            </div>
                        </div>

                        <button id="LoginBtn" type="submit" class="btn btn-primary w-100">
                            Login
                        </button>
                    </form>

                </div>

            </div>
        </div>
    </div>
    
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function togglePassword() {
            const password = document.getElementById('Password');
            const icon = document.querySelector('.toggle-password');

            if (password.type === 'text') {
                password.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            } else {
                password.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            }
        }

        $('#LoginForm').on('submit', function(e) {
            e.preventDefault();

            var email = $('#Email').val();
            var password = $('#Password').val();

            if (!email || !password) {
                showAlert('Please enter both email and password', 'danger');
                return;
            }

             $.ajax({
                url: '/api/auth/login',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    email: email,
                    password: password,
                }),
                success: function(response) {
                    if (response.success) {
                        // Store JWT token and user info
                        localStorage.setItem('jwt_token', response.token);
                        localStorage.setItem('role', response.role);
                        localStorage.setItem('username', response.username);

                        showAlert(response.message, 'success');

                        setTimeout(function() {
                            window.location.href = response.redirectUrl;
                        }, 1000);
                    } else {
                        showAlert(response.message, 'danger');
                    }
                    btn.prop('disabled', false);
                    btn.html('Login');
                },
                error: function(xhr) {
                    var errorMsg = 'Login failed. Please try again.';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMsg = xhr.responseJSON.message;
                    }
                    showAlert(errorMsg, 'danger');
                    btn.prop('disabled', false);
                    btn.html('Login');
                }
            });
        });

        function showAlert(message, type) {
            $('#alertMessage').html(
                '<div class="alert alert-' + type + ' alert-dismissible fade show" role="alert">' +
                    message +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                '</div>'
            );

            setTimeout(function() {
                $('.alert').alert('close');
            }, 3000);
        }
    </script>
</body>
</html>